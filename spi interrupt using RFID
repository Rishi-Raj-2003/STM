#include "stm32f4xx.h"
#include <stdint.h>

/* ================= CONFIG ================= */

#define OLED_ADDR  0x3C   // 7-bit address

/* ================= SIMPLE DELAY ================= */

void delay_ms(uint32_t ms)
{
    for(uint32_t i=0;i<ms*16000;i++);
}

/* ================= I2C INIT ================= */

void I2C1_init(void)
{
    RCC->AHB1ENR |= (1<<1);      // GPIOB
    RCC->APB1ENR |= (1<<21);     // I2C1

    /* PB6 SCL, PB7 SDA */
    GPIOB->MODER &= ~((3<<12)|(3<<14));
    GPIOB->MODER |=  ((2<<12)|(2<<14));   // AF mode

    GPIOB->OTYPER |= (1<<6)|(1<<7);       // Open drain
    GPIOB->OSPEEDR |= (3<<12)|(3<<14);    // High speed

    GPIOB->PUPDR &= ~((3<<12)|(3<<14));
    GPIOB->PUPDR |=  ((1<<12)|(1<<14));   // Pull-up

    GPIOB->AFR[0] &= ~((0xF<<24)|(0xF<<28));
    GPIOB->AFR[0] |=  ((4<<24)|(4<<28));  // AF4 I2C

    /* Reset I2C */
    I2C1->CR1 |= (1<<15);
    I2C1->CR1 &= ~(1<<15);

    /* 16 MHz PCLK1 */
    I2C1->CR2   = 16;
    I2C1->CCR   = 80;      // 100kHz
    I2C1->TRISE = 17;

    I2C1->CR1 |= 1;        // Enable
}

/* ================= LOW LEVEL WRITE ================= */

void I2C_write_multi(uint8_t control, uint8_t *data, uint16_t size)
{
    I2C1->CR1 |= (1<<8);                  // START
    while(!(I2C1->SR1 & (1<<0)));

    I2C1->DR = (OLED_ADDR << 1);          // address write
    while(!(I2C1->SR1 & (1<<1)));
    (void)I2C1->SR2;

    while(!(I2C1->SR1 & (1<<7)));
    I2C1->DR = control;

    for(uint16_t i=0;i<size;i++)
    {
        while(!(I2C1->SR1 & (1<<7)));
        I2C1->DR = data[i];
    }

    while(!(I2C1->SR1 & (1<<2)));          // BTF wait

    I2C1->CR1 |= (1<<9);                  // STOP
}

/* ================= OLED COMMAND ================= */

void OLED_cmd(uint8_t cmd)
{
    I2C_write_multi(0x00, &cmd, 1);
}

/* ================= OLED DATA ================= */

void OLED_data(uint8_t *data, uint16_t size)
{
    I2C_write_multi(0x40, data, size);
}

/* ================= OLED INIT ================= */

void OLED_init(void)
{
    delay_ms(100);

    OLED_cmd(0xAE);
    OLED_cmd(0x20); OLED_cmd(0x00);   // Horizontal mode
    OLED_cmd(0xB0);
    OLED_cmd(0xC8);
    OLED_cmd(0x00);
    OLED_cmd(0x10);
    OLED_cmd(0x40);
    OLED_cmd(0x81); OLED_cmd(0x7F);
    OLED_cmd(0xA1);
    OLED_cmd(0xA6);
    OLED_cmd(0xA8); OLED_cmd(0x3F);
    OLED_cmd(0xA4);
    OLED_cmd(0xD3); OLED_cmd(0x00);
    OLED_cmd(0xD5); OLED_cmd(0x80);
    OLED_cmd(0xD9); OLED_cmd(0xF1);
    OLED_cmd(0xDA); OLED_cmd(0x12);
    OLED_cmd(0xDB); OLED_cmd(0x40);
    OLED_cmd(0x8D); OLED_cmd(0x14);
    OLED_cmd(0xAF);
}

/* ================= CLEAR ================= */

void OLED_clear(void)
{
    uint8_t zero[128];
    for(int i=0;i<128;i++) zero[i]=0x00;

    for(int page=0; page<8; page++)
    {
        OLED_cmd(0xB0 + page);
        OLED_cmd(0x00);
        OLED_cmd(0x10);
        OLED_data(zero,128);
    }
}

/* ================= MAIN ================= */

int main(void)
{
    I2C1_init();
    OLED_init();
    OLED_clear();

    while(1)
    {
        // Fill screen test (to verify clean output)
        uint8_t full[128];
        for(int i=0;i<128;i++) full[i]=0xFF;

        for(int page=0; page<8; page++)
        {
            OLED_cmd(0xB0 + page);
            OLED_cmd(0x00);
            OLED_cmd(0x10);
            OLED_data(full,128);
        }

        delay_ms(1000);
        OLED_clear();
        delay_ms(1000);
    }
}

